# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Local Database (for messages, templates, scheduled)
DATABASE_URL=sqlite:///sms_dashboard.db

# Leads Database (Railway PostgreSQL - read-only connection to PNYC leads)
LEADS_DATABASE_URL=postgresql://user:pass@host:port/database

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your_secret_key_here

# Public base URL — used for OAuth callback, tracking pixels, unsubscribe links
# On Railway: https://your-app.railway.app
PUBLIC_BASE_URL=http://localhost:5000

# Google OAuth — required for connecting Gmail / Workspace sending mailboxes
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be {PUBLIC_BASE_URL}/api/email/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic — for AI-personalized email opening lines (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
